<UserControl
    x:Class="DesktopFilesGui.Controls.CheckBoxWithHelp"
    x:Name="RootControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Orientation="Horizontal">
        <CheckBox IsChecked="{Binding IsChecked, ElementName=RootControl}" Margin="5,10,0,0" />
        <TextBlock Margin="0,15,0,0" Text="{Binding Content, ElementName=RootControl}" />
        <Button
            BorderBrush="Transparent"
            Classes="outline"
            Content="{icons:MaterialIconExt Kind=QuestionMark}"
            Margin="20,10,0,0"
            Name="ClickButton"
            ToolTip.Tip="{Binding ToolTip, ElementName=RootControl}" />

    </StackPanel>
</UserControl>